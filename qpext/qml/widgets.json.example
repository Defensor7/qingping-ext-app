{
  "ha": {
    "base_url":     "http://10.0.0.0:8123",
    "token":        "PUT_LONG_LIVED_ACCESS_TOKEN_HERE"
  },
  "widgets": [
    { "type": "light",   "entity": "light.example",            "label": "Light",    "icon": "lightbulb" },
    { "type": "switch",  "entity": "switch.example",           "label": "Switch",   "icon": "toggle-switch" },
    { "type": "sensor",  "entity": "sensor.example",           "label": "Sensor",   "icon": "thermometer" },
    { "type": "button",  "label": "Run script",
      "service": "script.turn_on",
      "data":    { "entity_id": "script.example" },
      "icon":    "play" },
    { "type": "climate",      "entity": "climate.example",        "label": "AC",   "icon": "snowflake" },
    { "type": "media_player", "entity": "media_player.example",   "label": "TV",   "icon": "television" }
  ],
  "events": [
    { "entity": "automation.example_doorbell", "switch_to": "qpextCamerasView" }
  ]
}
