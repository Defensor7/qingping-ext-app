{
  "title": "Airmonitor App Extension",
  "config": {
    "flow_title": "{name}",
    "step": {
      "user": {
        "title": "Add an Airmonitor App Extension",
        "description": "Enter the device's Wi-Fi MAC address. Auto-discovery via MQTT usually finds the device on its own; use this manual form if it hasn't connected to the broker yet.",
        "data": {
          "mac": "MAC address"
        }
      },
      "discovery_confirm": {
        "title": "Discovered Airmonitor App Extension",
        "description": "An Airmonitor App Extension was discovered on MQTT.\n\n- MAC: {mac}\n- Model: {model}\n- Firmware: {sw}\n\nAdd it?"
      }
    },
    "error": {
      "invalid_mac": "MAC must be 12 hex digits."
    },
    "abort": {
      "already_configured": "A device with this MAC is already configured.",
      "invalid_discovery_topic": "Discovery topic is not in the expected form.",
      "invalid_mac": "Auto-discovery received an invalid MAC."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Airmonitor App Extension dashboard",
        "description": "Add, edit or remove widgets shown on the device's HA tab. Cameras add an RTSP tab (hidden when none configured).",
        "menu_options": {
          "add_widget": "Add a widget",
          "edit_widget": "Edit a widget",
          "remove_widget": "Remove a widget",
          "cameras_menu": "Cameras",
          "events_menu": "Triggers (events)",
          "finish": "Done"
        }
      },
      "add_widget": {
        "title": "Pick a widget type",
        "data": {"type": "Type"}
      },
      "add_entity_widget": {
        "title": "New {widget_type} widget",
        "data": {
          "entity": "HA entity",
          "label": "Label (optional)",
          "icon": "Icon (mdi:…)"
        }
      },
      "add_button": {
        "title": "New button widget",
        "data": {
          "label": "Label",
          "service": "Service (e.g. switch.turn_on)",
          "data": "Service data (JSON, optional)",
          "icon": "Icon (mdi:…)"
        }
      },
      "edit_widget": {"title": "Pick the widget to edit", "data": {"index": "Widget"}},
      "edit_entity_widget": {
        "title": "Edit {widget_type} widget",
        "data": {"entity": "HA entity", "label": "Label", "icon": "Icon"}
      },
      "edit_button": {
        "title": "Edit button widget",
        "data": {"label": "Label", "service": "Service", "data": "Service data (JSON)", "icon": "Icon"}
      },
      "remove_widget": {"title": "Pick the widget to remove", "data": {"index": "Widget"}},
      "cameras_menu": {
        "title": "Cameras",
        "menu_options": {
          "add_camera": "Add a camera",
          "edit_camera": "Edit a camera",
          "remove_camera": "Remove a camera",
          "init": "Back"
        }
      },
      "add_camera": {
        "title": "Add a camera",
        "data": {
          "name": "Name (ASCII)",
          "url": "RTSP URL",
          "label": "Label",
          "fps": "FPS",
          "width": "Width (px)"
        }
      },
      "edit_camera": {"title": "Pick the camera to edit", "data": {"index": "Camera"}},
      "edit_camera_form": {
        "title": "Edit camera",
        "description": "Current URL: {redacted}",
        "data": {"name": "Name", "url": "RTSP URL", "label": "Label", "fps": "FPS", "width": "Width (px)"}
      },
      "remove_camera": {"title": "Pick the camera to remove", "data": {"index": "Camera"}},
      "events_menu": {
        "title": "Triggers",
        "menu_options": {
          "add_event": "Add a trigger",
          "remove_event": "Remove a trigger",
          "init": "Back"
        }
      },
      "add_event": {
        "title": "New trigger",
        "data": {"entity": "Source HA entity", "switch_to": "Switch device to tab"}
      },
      "remove_event": {"title": "Pick a trigger to remove", "data": {"index": "Trigger"}}
    },
    "error": {
      "data_invalid_json": "Service data must be valid JSON.",
      "data_not_object": "Service data must be a JSON object.",
      "rtsp_only": "URL must start with rtsp://",
      "name_taken": "A camera with this name already exists."
    }
  },
  "services": {
    "republish": {
      "name": "Re-publish dashboard",
      "description": "Re-publish current widget composition to MQTT."
    }
  },
  "selector": {
    "widget_type": {
      "options": {
        "sensor": "Sensor (read-only)",
        "switch": "Switch (toggle)",
        "light": "Light (toggle + brightness)",
        "climate": "Climate (temp + setpoint)",
        "media_player": "Media player",
        "cover": "Cover",
        "script": "Script",
        "scene": "Scene",
        "button": "Button (service call)"
      }
    }
  }
}
