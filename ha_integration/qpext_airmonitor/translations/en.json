{
  "title": "Airmonitor App Extension",
  "config": {
    "flow_title": "{name}",
    "step": {
      "user": {
        "title": "Add an Airmonitor App Extension",
        "description": "Enter the device's Wi-Fi MAC address. Auto-discovery via MQTT usually finds the device on its own; use this manual form if it hasn't connected to the broker yet.",
        "data": {
          "mac": "MAC address"
        }
      },
      "discovery_confirm": {
        "title": "Discovered Airmonitor App Extension",
        "description": "An Airmonitor App Extension was discovered on MQTT.\n\n- MAC: {mac}\n- Model: {model}\n- Firmware: {sw}\n\nAdd it?"
      }
    },
    "error": {
      "invalid_mac": "MAC must be 12 hex digits."
    },
    "abort": {
      "already_configured": "A device with this MAC is already configured.",
      "invalid_discovery_topic": "Discovery topic is not in the expected form.",
      "invalid_mac": "Auto-discovery received an invalid MAC."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Airmonitor App Extension tabs",
        "description": "Each tab is either a set of widget cards or a single RTSP camera. The integration publishes a `Show <name>` button entity per tab.",
        "menu_options": {
          "add_tab": "Add a tab",
          "edit_tab": "Edit a tab",
          "remove_tab": "Remove a tab",
          "events_menu": "Triggers (events)",
          "weather_menu": "Weather feed",
          "finish": "Done"
        }
      },
      "weather_menu": {
        "title": "Weather feed",
        "description": "Current source: `{current}`.",
        "menu_options": {
          "edit_weather": "Pick HA source entities",
          "clear_weather": "Clear configuration",
          "init": "Back"
        }
      },
      "edit_weather": {
        "title": "Weather source entities",
        "data": {
          "weather_entity": "Weather entity",
          "aqi_entity": "AQI sensor",
          "uv_entity": "UV sensor",
          "humidity_entity": "Humidity sensor (optional)",
          "city_name": "City label"
        }
      },
      "add_tab": {
        "title": "New tab",
        "data": {
          "name": "Name",
          "type": "Type",
          "icon": "Show-tab button icon"
        }
      },
      "edit_tab": {"title": "Pick the tab to edit", "data": {"index": "Tab"}},
      "tab_menu": {
        "title": "{tab_name}",
        "description": "Editing tab `{tab_name}` ({tab_type}).",
        "menu_options": {
          "rename_tab": "Rename / change icon",
          "add_widget": "Add a widget",
          "edit_widget": "Edit a widget",
          "remove_widget": "Remove a widget",
          "edit_camera": "Edit the camera",
          "init": "Back"
        }
      },
      "rename_tab": {
        "title": "Rename {tab_name}",
        "data": {"name": "New name", "icon": "Icon"}
      },
      "remove_tab": {"title": "Pick a tab to remove", "data": {"index": "Tab"}},
      "edit_camera": {
        "title": "Camera for {tab_name}",
        "description": "Current URL: {redacted}",
        "data": {
          "url": "RTSP URL",
          "label": "Label",
          "fps": "FPS",
          "width": "Width (px)"
        }
      },
      "add_widget": {
        "title": "Pick a widget type",
        "data": {"type": "Type"}
      },
      "add_entity_widget": {
        "title": "New {widget_type} widget",
        "data": {
          "entity": "HA entity",
          "label": "Label (optional)",
          "icon": "Icon (mdi:…)",
          "title_size": "Title font size",
          "title_color": "Title color",
          "value_size": "Value font size",
          "value_color": "Value color",
          "icon_size": "Icon size",
          "icon_color": "Icon color",
          "bg_color": "Card background"
        }
      },
      "add_button": {
        "title": "New button widget",
        "data": {
          "label": "Label",
          "service": "Service (e.g. switch.turn_on)",
          "data": "Service data (JSON, optional)",
          "icon": "Icon (mdi:…)",
          "title_size": "Title font size",
          "title_color": "Title color",
          "value_size": "Value font size",
          "value_color": "Value color",
          "icon_size": "Icon size",
          "icon_color": "Icon color",
          "bg_color": "Card background"
        }
      },
      "edit_widget": {"title": "Pick the widget to edit", "data": {"index": "Widget"}},
      "edit_entity_widget": {
        "title": "Edit {widget_type} widget",
        "data": {
          "entity": "HA entity", "label": "Label", "icon": "Icon",
          "title_size": "Title font size", "title_color": "Title color",
          "value_size": "Value font size", "value_color": "Value color",
          "icon_size": "Icon size", "icon_color": "Icon color",
          "bg_color": "Card background"
        }
      },
      "edit_button": {
        "title": "Edit button widget",
        "data": {
          "label": "Label", "service": "Service", "data": "Service data (JSON)", "icon": "Icon",
          "title_size": "Title font size", "title_color": "Title color",
          "value_size": "Value font size", "value_color": "Value color",
          "icon_size": "Icon size", "icon_color": "Icon color",
          "bg_color": "Card background"
        }
      },
      "remove_widget": {"title": "Pick the widget to remove", "data": {"index": "Widget"}},
      "events_menu": {
        "title": "Triggers",
        "menu_options": {
          "add_event": "Add a trigger",
          "remove_event": "Remove a trigger",
          "init": "Back"
        }
      },
      "add_event": {
        "title": "New trigger",
        "data": {"entity": "Source HA entity", "switch_to": "Switch device to tab"}
      },
      "remove_event": {"title": "Pick a trigger to remove", "data": {"index": "Trigger"}}
    },
    "error": {
      "name_required": "Tab name is required.",
      "data_invalid_json": "Service data must be valid JSON.",
      "data_not_object": "Service data must be a JSON object.",
      "rtsp_only": "URL must start with rtsp://"
    }
  },
  "services": {
    "republish": {
      "name": "Re-publish dashboard",
      "description": "Re-publish current tab composition to MQTT."
    }
  },
  "selector": {
    "tab_type": {
      "options": {
        "widgets": "Widgets (set of cards)",
        "camera": "Camera (single RTSP feed)"
      }
    },
    "widget_type": {
      "options": {
        "sensor": "Sensor (read-only)",
        "switch": "Switch (toggle)",
        "light": "Light (toggle + brightness)",
        "climate": "Climate (temp + setpoint + on/off)",
        "media_player": "Media player",
        "cover": "Cover",
        "script": "Script",
        "scene": "Scene",
        "button": "Button (service call)"
      }
    }
  }
}
