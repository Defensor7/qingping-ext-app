# Secrets: cameras.json contains an RTSP URL with embedded credentials;
# widgets.json holds a long-lived Home Assistant access token. Keep the
# .example templates committed; copy and edit locally:
#   cp qpext/qml/widgets.json.example qpext/qml/widgets.json
#   cp qpext/qml/cameras.json.example qpext/qml/cameras.json
qpext/qml/cameras.json
qpext/qml/widgets.json
qpext/qml/mqtt.json
qpext/qml/ha.json
qpext/qml/version.txt

# Local debug stack state (HA storage, db, token cache).
dev/ha-config/
dev/mosquitto-data/

# Build outputs / proprietary device artifacts pulled for reverse engineering.
qpext/qpext.so
QingSnow2App
device_libs/
qrc_out/

